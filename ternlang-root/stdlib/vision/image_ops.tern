}

fn crop_trit(img: TritImage, x: int, y: int) -> TritImage {
    return img;
}

fn resize_trit(img: TritImage, scale: float) -> TritImage {
    return img;
}

fn normalize_image_trit(img: TritImage) -> TritImage {
    // Normalizes to -1, 0, 1
    return img;
}
